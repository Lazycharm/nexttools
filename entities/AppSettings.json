{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Setting key (unique identifier)"
    },
    "value": {
      "type": "string",
      "description": "Setting value"
    },
    "category": {
      "type": "string",
      "enum": [
        "general",
        "payments",
        "social",
        "notifications",
        "security"
      ]
    }
  },
  "required": [
    "key",
    "value"
  ]
}