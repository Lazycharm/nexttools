{
  "name": "Subscription",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "plan_name": {
      "type": "string"
    },
    "plan_tier": {
      "type": "string",
      "enum": [
        "starter",
        "growth",
        "pro",
        "elite",
        "agency"
      ]
    },
    "price": {
      "type": "number"
    },
    "billing_cycle": {
      "type": "string",
      "enum": [
        "monthly",
        "quarterly",
        "yearly"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "expired",
        "cancelled",
        "paused"
      ],
      "default": "active"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auto_renew": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "user_email",
    "plan_name",
    "price"
  ]
}